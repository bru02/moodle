{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "mobile",
      "moodlemobile"
    ],
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "me.toldy.moodle",
      "appleTeamId": "6978HVCRTY",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.moodle.mobile",
          "group.moodle.mobile"
        ]
      },
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "CFBundleIcons": {
          "ISGraphicIconConfiguration": {
            "ISEnclosureColor": "yellow",
            "ISSymbolColor": "black",
            "ISSymbolName": "graduationcap.fill"
          }
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "me.toldy.moodle"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@bacons/apple-targets",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "me.toldy.moodle.spotlight-delegate",
                  "targetName": "spotlightdelegate",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.moodle.mobile"
                    ]
                  }
                },
                {
                  "bundleIdentifier": "me.toldy.moodle.spotlight",
                  "targetName": "spotlight",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.moodle.mobile"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "ed77dd63-1bc6-43db-885b-b47d446e438c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ed77dd63-1bc6-43db-885b-b47d446e438c"
    }
  }
}
