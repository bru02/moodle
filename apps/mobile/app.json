{
  "expo": {
    "name": "Based Moodle",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "mobile",
      "moodlemobile"
    ],
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "me.toldy.moodle",
      "appleTeamId": "6978HVCRTY",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.moodle.mobile",
          "group.moodle.mobile"
        ]
      },
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "CFBundleIcons": {
          "ISGraphicIconConfiguration": {
            "ISEnclosureColor": "yellow",
            "ISSymbolColor": "black",
            "ISSymbolName": "graduationcap.fill"
          }
        },
        "NSUserActivityTypes": [
          "$(PRODUCT_BUNDLE_IDENTIFIER).expo.index_route",
          "me.toldy.moodle.view-course",
          "me.toldy.moodle.view-task"
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "100.84.235.89": {
              "NSIncludesSubdomains": true,
              "NSExceptionAllowsInsecureHTTPLoads": true
            }
          }
        },
        "NSCalendarsUsageDescription": "Allow $(PRODUCT_NAME) to read your calendar so it can match courses against existing events."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "me.toldy.moodle",
      "permissions": [
        "READ_CALENDAR"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@bacons/apple-targets",
      [
        "expo-font",
        {
          "fonts": [
            "../../node_modules/@expo-google-fonts/fira-code/400Regular/FiraCode_400Regular.ttf",
            "../../node_modules/@expo-google-fonts/fira-code/700Bold/FiraCode_700Bold.ttf"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Allow $(PRODUCT_NAME) to read your calendar so it can match courses against existing events."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "me.toldy.moodle.spotlight-delegate",
                  "targetName": "spotlightdelegate",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.moodle.mobile"
                    ]
                  }
                },
                {
                  "bundleIdentifier": "me.toldy.moodle.spotlight",
                  "targetName": "spotlight",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.moodle.mobile"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "ed77dd63-1bc6-43db-885b-b47d446e438c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ed77dd63-1bc6-43db-885b-b47d446e438c"
    }
  }
}
