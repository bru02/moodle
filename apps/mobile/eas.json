{
  "cli": {
    "version": ">= 16.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "RCT_HERMES_V1_ENABLED": "1"
      }
    },
    "development": {
      "autoIncrement": true,
      "developmentClient": true,
      "channel": "development",
      "env": {
        "RCT_HERMES_V1_ENABLED": "1"
      }
    }
  },
  "submit": {
    "production": {},
    "development": {}
  }
}
